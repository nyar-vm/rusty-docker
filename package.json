{
    "name": "docker",
    "private": true,
    "description": "OpenCrab - 基于模块化架构的 AI 助手框架",
    "repository": "https://github.com/oovm/opencrab",
    "homepage": "https://github.com/oovm/opencrab",
    "license": "MIT",
    "scripts": {
        "check:ci": "node scripts/check.mjs",
        "doc": "cargo doc --no-deps --all-features",
        "test": "cargo test --release",
        "fmt": "biome format --write && cargo fmt --all",
        "push": "git push && git push --tags --prune",
        "reset": "git reset HEAD~ --soft",
        "u": "cargo upgrade --incompatible",
        "p": "cargo workspaces publish --no-git-commit --allow-dirty --yes",
        "lint": "biome check",
        "lint:fix": "biome check --write",
        "format": "biome format --write"
    },
    "devDependencies": {
        "@biomejs/biome": "^1.9.4"
    },
    "dependencies": {
        "esbuild": "^0.27.4"
    }
}
